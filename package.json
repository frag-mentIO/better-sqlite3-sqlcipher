{
  "name": "@frag-ment/better-sqlite3-sqlcipher",
  "version": "0.1.0",
  "private": false,
  "description": "SQLCipher-enabled better-sqlite3 adapter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frag-mentIO/better-sqlite3-sqlcipher.git"
  },
  "homepage": "https://github.com/frag-mentIO/better-sqlite3-sqlcipher#readme",
  "bugs": {
    "url": "https://github.com/frag-mentIO/better-sqlite3-sqlcipher/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "scripts",
    "vendor/sqlcipher-amalgamation"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "pack": "mkdir -p build/packages && npm pack --pack-destination build/packages",
    "test": "vitest run --config tests/vitest.config.ts",
    "postinstall": "bash ./scripts/bootstrap.sh postinstall",
    "sqlcipher:bootstrap": "bash ./scripts/bootstrap.sh",
    "sqlcipher:bootstrap:strict": "bash ./scripts/bootstrap.sh strict",
    "sqlcipher:prepare": "bash ./scripts/prepare-amalgamation.sh",
    "sqlcipher:ensure": "bash ./scripts/ensure-electron-sqlcipher.sh",
    "sqlcipher:rebuild": "bash ./scripts/rebuild-electron-sqlcipher.sh",
    "sqlcipher:check": "bash ./scripts/check-runtime.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
